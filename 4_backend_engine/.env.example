# Backend secrets — never commit real values; never put these in 5_frontend/.env

TFL_APP_KEY=
TOMTOM_API_KEY=
ORS_API_KEY=

DB_USER=postgres
DB_PASS=
DB_NAME=london_routing
DB_HOST=localhost

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# Publishable / anon key — server-side password grants only (not in the React bundle)
SUPABASE_ANON_KEY=

# Mapbox Search Box — server proxy (Flask /geocode/*). Public pk. token OK.
# Same pk. may also be used as REACT_APP_MAPBOX_TOKEN for the map (prefer a
# URL-restricted frontend-only pk. for the browser).
MAPBOX_API_KEY=

# File-backed monthly hard cuts (~90% of free tier). See mapbox_usage.py.
# Search Box sessions free: 500/mo → default cut 450
# GL JS map loads free: 50_000/mo → default cut 45_000
# MAPBOX_USAGE_PATH=           # optional; default 4_backend_engine/mapbox_usage.json
MAPBOX_SEARCH_SESSION_LIMIT=450
MAPBOX_MAP_LOAD_LIMIT=45000
# Seed when creating the usage file for the current UTC month (align to dashboard)
MAPBOX_SEARCH_SESSIONS_USED=20
MAPBOX_MAP_LOADS_USED=0

PROFILE_STORE=auto
ALLOW_TEST_MODE=1
ROUTE_HEURISTIC_EPSILON=0.5
# Dev only: synthetic extreme weather on GET /weather (or use python app.py --weather-test)
# WEATHER_TEST_MODE=1
