# Backend secrets — never commit real values; never put these in 5_frontend/.env

TFL_APP_KEY=
TOMTOM_API_KEY=
ORS_API_KEY=

DB_USER=postgres
DB_PASS=
DB_NAME=london_routing
DB_HOST=localhost

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
# Publishable / anon key — server-side password grants only (not in the React bundle)
SUPABASE_ANON_KEY=

# Mapbox Search Box (proxied by Flask /geocode/*)
MAPBOX_API_KEY=

PROFILE_STORE=auto
ALLOW_TEST_MODE=1
ROUTE_HEURISTIC_EPSILON=0.5
